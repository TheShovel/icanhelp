{
  "name": "icanhelp",
  "version": "1.0.0",
  "description": "Linux desktop AI assistant",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "ELECTRON_DEV=true electron .",
    "test": "node --test 'src/main/store.test.js' 'src/main/tools.test.js' 'src/main/timing.test.js' 'src/renderer/renderer.test.js'",
    "build": "bash scripts/build.sh",
    "build:dir": "bash scripts/build.sh dir",
    "build:deb": "bash scripts/build.sh deb",
    "build:appimage": "bash scripts/build.sh AppImage"
  },
  "build": {
    "appId": "com.icanhelp.app",
    "productName": "icanhelp",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage",
        "dir"
      ],
      "icon": "build/icons",
      "category": "Utility",
      "synopsis": "Linux desktop AI assistant",
      "description": "Linux desktop AI assistant that runs as a transparent overlay"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-llama-cpp/**"
    ]
  },
  "keywords": [
    "ai",
    "assistant",
    "linux",
    "desktop"
  ],
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.6.0",
    "katex": "^0.17.0",
    "marked": "^12.0.2",
    "node-llama-cpp": "^3.19.0",
    "onnxruntime-node": "^1.14.0",
    "sharp": "^0.33.0",
    "tesseract.js": "^5.1.1"
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "electron-winstaller@5.4.0": true,
    "node-llama-cpp@3.19.0": true,
    "onnxruntime-node@1.14.0": true,
    "protobufjs@6.11.6": true,
    "sharp@0.32.6": true,
    "tesseract.js@5.1.1": true
  }
}
