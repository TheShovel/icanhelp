#!/usr/bin/env bash
# sys — universal Linux admin CLI. One vocabulary, any distro.
#
# The AI (and humans) only need to learn these subcommands; sys detects the
# distro and translates to the native tool (apt/dnf/pacman, systemd, ufw/nft,
# netplan, timedatectl, journalctl, etc). Universal tools (rsync, tar, find,
# openssl, ip, ss) are NOT wrapped — use them directly.
#
# Usage summary (see `sys help` for the full list):
#   sys pkg ...        # packages
#   sys svc ...        # systemd services
#   sys firewall ...   # ufw / firewalld / nftables
#   sys net ...        # interfaces, routes, dns, listeners
#   sys disk ...       # lsblk/df/du/findmnt
#   sys user ...       # useradd/usermod/id
#   sys group ...      # groupadd/groupmod/getent
#   sys time ...       # timedatectl
#   sys log ...        # journalctl
#   sys kern ...       # modules + initramfs
#   sys secure ...     # SELinux / AppArmor status
#   sys ssh ...        # key generation
#   sys swap ...       # swap / zram
#   sys perf ...       # resource snapshots
#   sys detect | help
#
# Notes:
#   - sudo is auto-prepended when the invoking user is not root.
#   - Destructive ops (remove/purge/reset/swap file) act immediately; the AI
#     should confirm with the user before running them.
set -euo pipefail

SYS_LIB="$(cd "$(dirname "$0")" && pwd)/sys-common"
# shellcheck disable=SC1091
. "$SYS_LIB"

cmd="${1:-help}"; shift || true

case "$cmd" in
  detect) sys_detect ;;

  pkg)
    sub="${1:-}"; shift || true
    case "$sub" in
      update)        pkg_update ;;
      upgrade)       pkg_upgrade ;;
      install)       need_args "$@"; pkg_install "$@" ;;
      remove)        need_args "$@"; pkg_remove "$@" ;;
      purge)         need_args "$@"; pkg_purge "$@" ;;
      search)        need_args "$@"; pkg_search "$@" ;;
      info)          need_args "$@"; pkg_info "$@" ;;
      list-installed) pkg_list_installed ;;
      owns)          need_args "$@"; pkg_owns "$@" ;;
      files)         need_args "$@"; pkg_files "$@" ;;
      clean)         pkg_clean ;;
      check)         pkg_check ;;
      *) die "Unknown pkg subcommand: $sub (try: update|upgrade|install|remove|purge|search|info|list-installed|owns|files|clean|check)" ;;
    esac ;;

  svc)
    sub="${1:-}"; shift || true
    case "$sub" in
      status|start|stop|restart|enable|disable|mask|unmask)
        need_args "$@"; svc_"$sub" "$@" ;;
      *) die "Unknown svc subcommand: $sub (try: status|start|stop|restart|enable|disable|mask|unmask)" ;;
    esac ;;

  firewall)
    sub="${1:-}"; shift || true
    case "$sub" in
      status) firewall_status ;;
      allow)  need_args "$@"; firewall_allow "$@" ;;
      deny)   need_args "$@"; firewall_deny "$@" ;;
      reset)  firewall_reset ;;
      *) die "Unknown firewall subcommand: $sub (try: status|allow|deny|reset)" ;;
    esac ;;

  net)
    sub="${1:-}"; shift || true
    case "$sub" in
      apply)      net_apply ;;
      interfaces) net_interfaces ;;
      routes)     net_routes ;;
      dns)        net_dns ;;
      listen)     net_listen ;;
      scan)       need_args "$@"; net_scan "$@" ;;
      *) die "Unknown net subcommand: $sub (try: apply|interfaces|routes|dns|listen|scan)" ;;
    esac ;;

  disk)
    sub="${1:-}"; shift || true
    case "$sub" in
      list)   disk_list ;;
      usage)  disk_usage ;;
      fs)     fs_usage "$@" ;;
      mounts) fs_mounts ;;
      *) die "Unknown disk subcommand: $sub (try: list|usage|fs|mounts)" ;;
    esac ;;

  user)
    sub="${1:-}"; shift || true
    case "$sub" in
      add)  need_args "$@"; user_add "$@" ;;
      del)  need_args "$@"; user_del "$@" ;;
      mod)  need_args "$@"; user_mod "$@" ;;
      info) need_args "$@"; user_info "$@" ;;
      list) user_list ;;
      *) die "Unknown user subcommand: $sub (try: add|del|mod|info|list)" ;;
    esac ;;

  group)
    sub="${1:-}"; shift || true
    case "$sub" in
      add)  need_args "$@"; group_add "$@" ;;
      del)  need_args "$@"; group_del "$@" ;;
      mod)  need_args "$@"; group_mod "$@" ;;
      list) group_list ;;
      *) die "Unknown group subcommand: $sub (try: add|del|mod|list)" ;;
    esac ;;

  time)
    sub="${1:-}"; shift || true
    case "$sub" in
      status) time_status ;;
      set)    need_args "$@"; time_set "$@" ;;
      zone)   need_args "$@"; time_zone "$@" ;;
      ntp)    time_ntp "${1:-on}" ;;
      zones)  time_zones ;;
      *) die "Unknown time subcommand: $sub (try: status|set|zone|ntp|zones)" ;;
    esac ;;

  log)
    sub="${1:-}"; shift || true
    case "$sub" in
      show)    log_show "$@" ;;
      follow)  log_follow "$@" ;;
      errors)  log_errors ;;
      boot)    log_boot ;;
      disk)    log_disk ;;
      vacuum)  need_args "$@"; log_vacuum "$@" ;;
      *) die "Unknown log subcommand: $sub (try: show|follow|errors|boot|disk|vacuum)" ;;
    esac ;;

  kern)
    sub="${1:-}"; shift || true
    case "$sub" in
      lsmod)     kern_lsmod ;;
      modinfo)   need_args "$@"; kern_modinfo "$@" ;;
      modprobe)  need_args "$@"; kern_modprobe "$@" ;;
      rmmod)     need_args "$@"; kern_rmmod "$@" ;;
      blacklist) need_args "$@"; kern_blacklist "$@" ;;
      initramfs) kern_initramfs ;;
      *) die "Unknown kern subcommand: $sub (try: lsmod|modinfo|modprobe|rmmod|blacklist|initramfs)" ;;
    esac ;;

  secure)
    sub="${1:-}"; shift || true
    case "$sub" in
      status) secure_status ;;
      audit)  secure_audit ;;
      *) die "Unknown secure subcommand: $sub (try: status|audit)" ;;
    esac ;;

  ssh)
    sub="${1:-}"; shift || true
    case "$sub" in
      key) need_args "$@"; ssh_key "$@" ;;
      pub) ssh_pub "${1:-ed25519}" ;;
      *) die "Unknown ssh subcommand: $sub (try: key|pub)" ;;
    esac ;;

  swap)
    sub="${1:-}"; shift || true
    case "$sub" in
      status) swap_status ;;
      on)     need_args "$@"; swap_on "$@" ;;
      off)    need_args "$@"; swap_off "$@" ;;
      file)   need_args "$@"; swap_file "$@" ;;
      *) die "Unknown swap subcommand: $sub (try: status|on|off|file)" ;;
    esac ;;

  perf)
    sub="${1:-}"; shift || true
    case "$sub" in
      top)  perf_top ;;
      mem)  perf_mem ;;
      load) perf_load ;;
      io)   perf_io ;;
      cpu)  perf_cpu ;;
      *) die "Unknown perf subcommand: $sub (try: top|mem|load|io|cpu)" ;;
    esac ;;

  help|--help|-h) sys_help ;;
  *) die "Unknown command: $cmd (try: pkg|svc|firewall|net|disk|user|group|time|log|kern|secure|ssh|swap|perf|detect|help)" ;;
esac
