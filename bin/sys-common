#!/usr/bin/env bash
# sys-common — shared helpers for the `sys` universal CLI.
# Sourced by bin/sys and bin/sys-detect. Not executed directly.

# ---- sudo helper: prepend sudo unless we are already root ----
sudo_if_needed() {
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
  else
    sudo "$@"
  fi
}

need_args() {
  if [ "$#" -eq 0 ]; then
    echo "Error: this subcommand requires at least one argument." >&2
    exit 2
  fi
}

die() { echo "Error: $*" >&2; exit 1; }

# ---- distro detection (cached) ----
sys_detect() {
  if [ -n "${SYS_DETECT_CACHE:-}" ]; then
    echo "$SYS_DETECT_CACHE"
    return
  fi
  local out
  out="$("$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/sys-detect")"
  SYS_DETECT_CACHE="$out"
  echo "$out"
}

# Read one KEY from sys-detect output.
_detect_val() {
  local key="$1"
  sys_detect | tr ' ' '\n' | grep "^${key}=" | head -1 | cut -d= -f2-
}

FAMILY="$(_detect_val family)"
PKG="$(_detect_val pkg)"
FIREWALL="$(_detect_val firewall)"
SSH_UNIT="$(_detect_val ssh_unit)"
INITRAMFS_CMD="$(_detect_val initramfs)"

# =====================================================================
# PACKAGE MANAGEMENT
# =====================================================================
pkg_update() {
  case "$PKG" in
    apt)    sudo_if_needed apt-get update ;;
    pacman) sudo_if_needed pacman -Sy ;;
    dnf)    sudo_if_needed dnf check-update || true ;;
    zypper) sudo_if_needed zypper refresh ;;
    *) die "No package manager detected (family=$FAMILY)" ;;
  esac
}

pkg_upgrade() {
  case "$PKG" in
    apt)    sudo_if_needed apt-get upgrade -y ;;
    pacman) sudo_if_needed pacman -Syu --noconfirm ;;
    dnf)    sudo_if_needed dnf upgrade -y ;;
    zypper) sudo_if_needed zypper update -y ;;
    *) die "No package manager detected (family=$FAMILY)" ;;
  esac
}

pkg_install() {
  case "$PKG" in
    apt)    sudo_if_needed apt-get install -y "$@" ;;
    pacman) sudo_if_needed pacman -S --noconfirm "$@" ;;
    dnf)    sudo_if_needed dnf install -y "$@" ;;
    zypper) sudo_if_needed zypper install -y "$@" ;;
    *) die "No package manager detected (family=$FAMILY)" ;;
  esac
}

pkg_remove() {
  case "$PKG" in
    apt)    sudo_if_needed apt-get remove -y "$@" ;;
    pacman) sudo_if_needed pacman -R --noconfirm "$@" ;;
    dnf)    sudo_if_needed dnf remove -y "$@" ;;
    zypper) sudo_if_needed zypper remove -y "$@" ;;
    *) die "No package manager detected (family=$FAMILY)" ;;
  esac
}

pkg_purge() {
  case "$PKG" in
    apt)    sudo_if_needed apt-get purge -y "$@" ;;
    pacman) sudo_if_needed pacman -Rns --noconfirm "$@" ;;
    dnf)    sudo_if_needed dnf remove -y "$@" ;;
    zypper) sudo_if_needed zypper remove -y "$@" ;;
    *) die "No package manager detected (family=$FAMILY)" ;;
  esac
}

pkg_search() {
  case "$PKG" in
    apt)    apt-cache search "$@" ;;
    pacman) pacman -Ss "$@" ;;
    dnf)    dnf search "$@" ;;
    zypper) zypper search "$@" ;;
    *) die "No package manager detected (family=$FAMILY)" ;;
  esac
}

pkg_info() {
  case "$PKG" in
    apt)    apt-cache show "$@" ;;
    pacman) pacman -Si "$@" ;;
    dnf)    dnf info "$@" ;;
    zypper) zypper info "$@" ;;
    *) die "No package manager detected (family=$FAMILY)" ;;
  esac
}

pkg_list_installed() {
  case "$PKG" in
    apt)    dpkg-query -W -f='${Package} ${Version}\n' ;;
    pacman) pacman -Q ;;
    dnf)    dnf list installed ;;
    zypper) zypper search --installed-only ;;
    *) die "No package manager detected (family=$FAMILY)" ;;
  esac
}

pkg_owns() {
  case "$PKG" in
    apt)    sudo_if_needed dpkg -S "$@" ;;
    pacman) pacman -Qo "$@" ;;
    dnf)    sudo_if_needed rpm -qf "$@" ;;
    zypper) sudo_if_needed rpm -qf "$@" ;;
    *) die "No package manager detected (family=$FAMILY)" ;;
  esac
}

pkg_files() {
  case "$PKG" in
    apt)    dpkg -L "$@" ;;
    pacman) pacman -Ql "$@" ;;
    dnf)    rpm -ql "$@" ;;
    zypper) rpm -ql "$@" ;;
    *) die "No package manager detected (family=$FAMILY)" ;;
  esac
}

pkg_clean() {
  case "$PKG" in
    apt)    sudo_if_needed apt-get clean ;;
    pacman) sudo_if_needed pacman -Sc --noconfirm ;;
    dnf)    sudo_if_needed dnf clean all ;;
    zypper) sudo_if_needed zypper clean ;;
    *) die "No package manager detected (family=$FAMILY)" ;;
  esac
}

# =====================================================================
# SERVICE MANAGEMENT (systemd on all supported families)
# =====================================================================
svc_status()  { sudo_if_needed systemctl status "$@" ; }
svc_start()   { sudo_if_needed systemctl start "$@" ; }
svc_stop()    { sudo_if_needed systemctl stop "$@" ; }
svc_restart() { sudo_if_needed systemctl restart "$@" ; }
svc_enable()  { sudo_if_needed systemctl enable "$@" ; }
svc_disable() { sudo_if_needed systemctl disable "$@" ; }
svc_mask()    { sudo_if_needed systemctl mask "$@" ; }
svc_unmask()  { sudo_if_needed systemctl unmask "$@" ; }

# =====================================================================
# FIREWALL
# =====================================================================
firewall_status() {
  case "$FIREWALL" in
    ufw)       sudo_if_needed ufw status verbose ;;
    firewalld) sudo_if_needed firewall-cmd --list-all ;;
    nftables)  sudo_if_needed nft list ruleset ;;
    *)         sudo_if_needed iptables -L -n -v 2>/dev/null || die "No firewall detected" ;;
  esac
}

# allow/deny take "port" or "port/proto" (proto defaults to tcp)
firewall_allow() {
  local target="$1"; local port="${target%/*}"; local proto="${target#*/}"
  [ "$proto" = "$target" ] && proto=tcp
  case "$FIREWALL" in
    ufw)       sudo_if_needed ufw allow "${port}/${proto}" ;;
    firewalld) sudo_if_needed firewall-cmd --add-port="${port}/${proto}" --permanent
               sudo_if_needed firewall-cmd --reload ;;
    nftables)  sudo_if_needed nft add rule inet filter input tcp dport "$port" accept ;;
    *)         sudo_if_needed iptables -A INPUT -p "$proto" --dport "$port" -j ACCEPT ;;
  esac
}

firewall_deny() {
  local target="$1"; local port="${target%/*}"; local proto="${target#*/}"
  [ "$proto" = "$target" ] && proto=tcp
  case "$FIREWALL" in
    ufw)       sudo_if_needed ufw deny "${port}/${proto}" ;;
    firewalld) sudo_if_needed firewall-cmd --remove-port="${port}/${proto}" --permanent
               sudo_if_needed firewall-cmd --reload ;;
    nftables)  sudo_if_needed nft add rule inet filter input tcp dport "$port" drop ;;
    *)         sudo_if_needed iptables -A INPUT -p "$proto" --dport "$port" -j DROP ;;
  esac
}

firewall_reset() {
  case "$FIREWALL" in
    ufw)       sudo_if_needed ufw --force reset ;;
    firewalld) sudo_if_needed firewall-cmd --reset-to-defaults ;;
    nftables)  sudo_if_needed nft flush ruleset ;;
    *)         sudo_if_needed iptables -F ;;
  esac
}

# =====================================================================
# NETWORKING (inspection — config files are distro-specific)
# =====================================================================
net_apply() {
  if command -v netplan >/dev/null 2>&1; then
    sudo_if_needed netplan apply
  elif [ "$FAMILY" = "arch" ]; then
    sudo_if_needed systemctl restart systemd-networkd
  else
    die "No known network renderer (netplan/systemd-networkd) found"
  fi
}

net_interfaces() { ip -br addr show; }
net_routes()     { ip route show; }
net_dns() {
  if command -v resolvectl >/dev/null 2>&1; then resolvectl status
  else cat /etc/resolv.conf; fi
}
net_listen() { ss -tulnp; }
net_scan() {
  need_args "$@"
  sudo_if_needed ss -tulnp | grep -E ":(${1// /|})" || echo "No listener on $*"
}

# =====================================================================
# DISK & FILESYSTEM (read-only inspection; universal tools)
# =====================================================================
disk_list()  { lsblk -f; }
disk_usage() { df -h; }
fs_usage()   { du -sh "${1:-.}"; }
fs_mounts()  { findmnt; }

# =====================================================================
# USERS & GROUPS
# =====================================================================
user_add() {
  need_args "$@"
  sudo_if_needed useradd -m -s /bin/bash "$@"
}
user_del() {
  need_args "$@"
  sudo_if_needed userdel -r "$@"
}
user_mod()    { need_args "$@"; sudo_if_needed usermod "$@" ; }
user_info()   { need_args "$@"; for u in "$@"; do id "$u"; done ; }
user_list()   { getent passwd ; }
group_add()   { need_args "$@"; sudo_if_needed groupadd "$@" ; }
group_del()   { need_args "$@"; sudo_if_needed groupdel "$@" ; }
group_mod()   { need_args "$@"; sudo_if_needed groupmod "$@" ; }
group_list()  { getent group ; }

# =====================================================================
# TIME & DATE (systemd on all supported families)
# =====================================================================
time_status() { timedatectl status; }
time_set()    { need_args "$@"; sudo_if_needed timedatectl set-time "$@" ; }
time_zone()   { need_args "$@"; sudo_if_needed timedatectl set-timezone "$@" ; }
time_ntp() {
  case "${1:-on}" in
    on)  sudo_if_needed timedatectl set-ntp true ;;
    off) sudo_if_needed timedatectl set-ntp false ;;
    *) die "Usage: sys time ntp [on|off]" ;;
  esac
}
time_zones() { timedatectl list-timezones ; }

# =====================================================================
# LOGGING (journald is universal on systemd distros)
# =====================================================================
log_show() {
  # log_show [unit] — show journal for a unit or the whole system
  if [ "$#" -gt 0 ]; then sudo_if_needed journalctl -u "$@"
  else sudo_if_needed journalctl; fi
}
log_follow() {
  if [ "$#" -gt 0 ]; then sudo_if_needed journalctl -u "$@" -f
  else sudo_if_needed journalctl -f; fi
}
log_errors() { sudo_if_needed journalctl -p err -b ; }
log_boot()   { sudo_if_needed journalctl -b ; }
log_disk()    { sudo_if_needed journalctl --disk-usage ; }
log_vacuum()  { need_args "$@"; sudo_if_needed journalctl --vacuum-size="$@" ; }

# =====================================================================
# KERNEL MODULES & INITRAMFS
# =====================================================================
kern_lsmod()    { lsmod ; }
kern_modinfo()  { need_args "$@"; modinfo "$@" ; }
kern_modprobe() { need_args "$@"; sudo_if_needed modprobe "$@" ; }
kern_rmmod()    { need_args "$@"; sudo_if_needed rmmod "$@" ; }
kern_blacklist() {
  # kern blacklist <module> — persistently block a module
  need_args "$@"
  local m="$1"
  echo "blacklist $m" | sudo_if_needed tee /etc/modprobe.d/disable-$m.conf
}
kern_initramfs() {
  [ -n "$INITRAMFS_CMD" ] || die "No initramfs rebuild command for family=$FAMILY"
  sudo_if_needed $INITRAMFS_CMD
}

# =====================================================================
# SECURITY STATUS (SELinux / AppArmor)
# =====================================================================
secure_status() {
  if command -v getenforce >/dev/null 2>&1; then
    echo "SELinux: $(getenforce)"
    sudo_if_needed sestatus 2>/dev/null | head -5
  elif command -v aa-status >/dev/null 2>&1; then
    echo "AppArmor profiles:"; sudo_if_needed aa-status 2>/dev/null | head -10
  else
    echo "No MAC framework (SELinux/AppArmor) detected — standard DAC only."
  fi
}
secure_audit() {
  if command -v ausearch >/dev/null 2>&1; then
    sudo_if_needed ausearch -m avc -ts recent 2>/dev/null || echo "No recent AVC denials."
  else
    echo "auditd/ausearch not installed."
  fi
}

# =====================================================================
# SSH KEY MANAGEMENT (universal)
# =====================================================================
ssh_key() {
  # ssh key <type> <comment> — generate an ed25519 (default) or rsa key
  local type="${1:-ed25519}"; local comment="${2:-$(whoami)@$(hostname)}"
  local out="$HOME/.ssh/id_$type"
  need_args "$type"
  mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
  if [ "$type" = "rsa" ]; then
    ssh-keygen -t rsa -b 4096 -o -a 100 -C "$comment" -f "$out"
  else
    ssh-keygen -t "$type" -a 100 -C "$comment" -f "$out"
  fi
}
ssh_pub() {
  local type="${1:-ed25519}"
  cat "$HOME/.ssh/id_$type.pub" 2>/dev/null || die "No $type public key found"
}

# =====================================================================
# SWAP & ZRAM
# =====================================================================
swap_status() { swapon --show; free -h; }
swap_on() {
  need_args "$@"
  sudo_if_needed swapon "$@"
}
swap_off() {
  need_args "$@"
  sudo_if_needed swapoff "$@"
}
swap_file() {
  # swap file <path> <size> — create + enable a swap file (e.g. sys swap file /swapfile 8G)
  need_args "$@"
  local path="$1" size="${2:-4G}"
  sudo_if_needed fallocate -l "$size" "$path" 2>/dev/null || \
    sudo_if_needed dd if=/dev/zero of="$path" bs=1M "count=${size%G}024" 2>/dev/null
  sudo_if_needed chmod 600 "$path"
  sudo_if_needed mkswap "$path"
  sudo_if_needed swapon "$path"
  echo "Add to /etc/fstab: $path none swap sw 0 0"
}

# =====================================================================
# PERFORMANCE SNAPSHOT (universal tools)
# =====================================================================
perf_top()    { top -b -n1 | head -20 ; }
perf_mem()    { free -h ; }
perf_load()   { cat /proc/loadavg ; uptime ; }
perf_io()     { vmstat 1 2 ; }
perf_cpu()    { lscpu | grep -E "Model name|CPU\(s\)|MHz" ; }

# =====================================================================
# HELP
# =====================================================================
sys_help() {
  cat <<'EOF'
sys — universal Linux admin CLI (auto-detects your distro)

  sys pkg update | upgrade | install <p...> | remove <p...> | purge <p...>
         search <q> | info <p> | list-installed | owns <file> | files <p> | clean

  sys svc status|start|stop|restart|enable|disable|mask|unmask <unit>

  sys firewall status | allow <port[/proto]> | deny <port[/proto]> | reset

  sys net apply | interfaces | routes | dns | listen | scan <port>
  sys disk list | usage | fs <path> | mounts
  sys user add|del|mod|info|list <args>      sys group add|del|mod|list <args>
  sys time status|set "<t>"|zone <tz>|ntp [on|off]|zones
  sys log show [unit] | follow [unit] | errors | boot | disk | vacuum <size>
  sys kern lsmod|modinfo|modprobe|rmmod <m> | blacklist <m> | initramfs
  sys secure status | audit
  sys ssh key [ed25519|rsa] [comment] | pub [type]
  sys swap status|on|off <dev> | file <path> <size>
  sys perf top|mem|load|io|cpu

  sys detect               # show detected distro + tooling
  sys help                 # this message

Detected environment:
EOF
  sys_detect | sed 's/^/  /'
}
